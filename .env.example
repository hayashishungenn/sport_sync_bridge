SYNC_SOURCES=igpsport,onelap
SYNC_TARGETS=garmin,strava
SYNC_LOOKBACK_DAYS=30
SYNC_POLL_INTERVAL_SECONDS=900
SYNC_DATA_DIR=.data
SYNC_LOG_LEVEL=INFO

IGPSPORT_USERNAME=
IGPSPORT_PASSWORD=
IGPSPORT_ACCESS_TOKEN=
IGPSPORT_COORD_MODE=gcj02_to_wgs84
