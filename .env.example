ONELAP_USERNAME=
ONELAP_PASSWORD=
ONELAP_COOKIE=
ONELAP_COORD_MODE=gcj02_to_wgs84
ONELAP_COORD_STRICT=false

GARMIN_EMAIL=
GARMIN_PASSWORD=
GARMIN_SESSION_B64=

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost/exchange_token
STRAVA_REFRESH_TOKEN=
STRAVA_ACCESS_TOKEN=
STRAVA_EXPIRES_AT=
STRAVA_SCOPE=
